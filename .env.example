# Optional. If set, shift posts are generated with the Claude API (claude-opus-4-8).
# If unset, the app falls back to a built-in deterministic demo engine so it runs
# out-of-the-box with zero configuration.
#
# Copy this file to .env.local and add your key (do NOT commit .env.local):
#   cp .env.example .env.local
ANTHROPIC_API_KEY=

# Optional. Override the model used for generation. Defaults to claude-opus-4-8.
# For a faster/cheaper demo you can set this to claude-haiku-4-5 or claude-sonnet-4-6.
# SHIFT_ASSISTANT_MODEL=claude-opus-4-8
